generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id              String   @id @default(cuid())
  businessName    String
  placeId         String?  @unique
  website         String?
  phone           String?
  city            String?
  category        String?
  address         String?
  rating          Float?
  reviewsCount    Int?     @default(0)
  auditScore      Int?
  auditIssues     String[]
  aiMessageDraft  String? @db.Text 
  status          LeadStatus @default(SCRAPED)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastScrapedAt   DateTime?

  @@index([status])
  @@index([city, category])
  @@index([createdAt])
}

enum LeadStatus {
  SCRAPED
  AUDITED
  MESSAGED
  CONVERTED
  REJECTED
}